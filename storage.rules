rules_version = '2';

// Firebase Storage Security Rules
service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow authenticated users to upload to products/temp folder
    match /products/temp/{allPaths=**} {
      allow read: if true; // Public read
      allow write: if request.auth != null; // Authenticated write
    }
    
    // Allow authenticated users to upload to products folder
    match /products/{allPaths=**} {
      allow read: if true; // Public read
      allow write: if request.auth != null; // Authenticated write
    }
    
    // Allow authenticated users to upload to generated folder
    match /generated/{allPaths=**} {
      allow read: if true; // Public read
      allow write: if request.auth != null; // Authenticated write
    }
    
    // Default deny all other paths
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
